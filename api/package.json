{
  "name": "estate-checkout-api",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker + D1 sync API for Estate Checkout",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create estate-checkout",
    "db:migrate:local": "wrangler d1 migrations apply estate-checkout --local",
    "db:migrate:remote": "wrangler d1 migrations apply estate-checkout --remote",
    "db:console:local": "wrangler d1 execute estate-checkout --local --command",
    "db:console:remote": "wrangler d1 execute estate-checkout --remote --command",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
